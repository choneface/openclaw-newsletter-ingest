# Gmail (IMAP + app password)
# Generate at https://myaccount.google.com/apppasswords (requires 2FA on the account).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_FOLDER=INBOX

# Anthropic
# On the openclaw VPS, leave ANTHROPIC_API_KEY blank and set OPENCLAW_ENV to the
# openclaw docker-compose .env file — this CLI will read the key from there so
# you don't duplicate the secret. Anywhere else, set ANTHROPIC_API_KEY directly.
ANTHROPIC_API_KEY=
OPENCLAW_ENV=/docker/openclaw-874u/.env
CLAUDE_MODEL=claude-sonnet-4-6

# DB — host path on the VPS, in the openclaw data volume.
# (The agent reads this same file from inside the container at the equivalent
# /data/.openclaw/... path, so leaving it under workspace-weekendercrix keeps
# the data scoped to that one agent.)
DB_PATH=/docker/openclaw-874u/data/.openclaw/workspace-weekendercrix/data/newsletters.db

# Logging
LOG_LEVEL=INFO
